{
  "name": "signflow",
  "version": "0.0.1",
  "description": "React <SignaturePad /> component for SignFlow, a self-hosted e-signature SDK",
  "keywords": [
    "signature",
    "e-signature",
    "esignature",
    "digital-signature",
    "signature-pad",
    "react",
    "react-component",
    "docusign-alternative",
    "hellosign-alternative",
    "typescript",
    "signflow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ubaton/sign-flow.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Ubaton/sign-flow#readme",
  "bugs": {
    "url": "https://github.com/Ubaton/sign-flow/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "signflow-core": "0.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
