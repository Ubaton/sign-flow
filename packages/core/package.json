{
  "name": "signflow-core",
  "version": "0.0.3",
  "description": "Framework-agnostic signature capture logic and API client for SignFlow",
  "keywords": [
    "signature",
    "e-signature",
    "esignature",
    "digital-signature",
    "signature-pad",
    "signature-capture",
    "svg",
    "canvas",
    "pointer-events",
    "docusign-alternative",
    "hellosign-alternative",
    "typescript",
    "signflow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ubaton/sign-flow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ubaton/sign-flow#readme",
  "bugs": {
    "url": "https://github.com/Ubaton/sign-flow/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
